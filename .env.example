# 复制为 .env 后填写真实值
# docker compose 会自动加载 .env 文件

# ========== LLM API Key ==========
UI_BUILDER_LLM_KEY=apg_fc41d3359cf837f17a4809bc4c19c6630d1c858246e0da9b
VIDEO_ANALYZE_LLM_KEY=apg_fc41d3359cf837f17a4809bc4c19c6630d1c858246e0da9b

# ========== API 鉴权 Token ==========
# 调用方式: Authorization: Bearer <token>（与调 LLM API 一样）
# 多个 token 用英文逗号分隔；留空则关闭鉴权（本地开发）
AUTH_TOKENS=

# ========== Nacos ==========
NACOS_AUTH_TOKEN=your-secret-token-at-least-32-chars-long
NACOS_IDENTITY_VALUE=your-identity-value
